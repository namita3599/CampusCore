generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STUDENT
  TEACHER
  WARDEN
}

enum FeeType {
  TUITION
  HOSTEL
}

enum FeeStatus {
  PAID
  UNPAID
}

model User {
  id                  Int             @id @default(autoincrement())
  username            String          @unique
  email               String?         @unique
  hashedPassword      String
  role                Role
  forcePasswordChange Boolean         @default(true)
  createdAt           DateTime        @default(now())
  studentProfile      StudentProfile?
  teacherProfile      TeacherProfile?
  wardenProfile       WardenProfile?
  heldRooms           Room[]          @relation("RoomHeldByUser")
  bookedRoom          Room?           @relation("RoomBookedByUser")
  announcementReads   AnnouncementRead[]
}

model StudentProfile {
  id               Int              @id @default(autoincrement())
  userId           Int              @unique
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  branch           String
  rollNumber       String?          @unique
  phone            String?
  guardianName     String?
  yearOfAdmission  Int?
  bloodGroup       String?
  courseRegistered Boolean          @default(false)
  tuitionPaid      Boolean          @default(false)
  hostelPaid       Boolean          @default(false)
  studentSubjects  StudentSubject[]
  studentHostels   StudentHostel[]
  feeRecords       FeeRecord[]
}

model TeacherProfile {
  id       Int      @id @default(autoincrement())
  userId   Int      @unique
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name     String
  phone    String?
  subjects Subject[] @relation("TeacherSubject")
}

model WardenProfile {
  id      Int      @id @default(autoincrement())
  userId  Int      @unique
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name    String
  phone   String?
  hostels Hostel[] @relation("WardenHostel")
}

model Subject {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  teacherId       Int?
  teacher         TeacherProfile?  @relation("TeacherSubject", fields: [teacherId], references: [id], onDelete: SetNull)
  studentSubjects StudentSubject[]
}

model Hostel {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  wardenId       Int?
  warden         WardenProfile?  @relation("WardenHostel", fields: [wardenId], references: [id], onDelete: SetNull)
  studentHostels StudentHostel[]
  rooms          Room[]
}

model StudentSubject {
  studentId  Int
  subjectId  Int
  enrolledAt DateTime       @default(now())
  student    StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject    Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([studentId, subjectId])
}

model StudentHostel {
  studentId Int
  hostelId  Int
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  hostel    Hostel         @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  @@id([studentId, hostelId])
}

model Room {
  id             String         @id @default(uuid())
  roomNumber     String         @unique
  status         String         @default("AVAILABLE") // "AVAILABLE", "HELD", "BOOKED"
  heldByUserId   Int?
  heldByUser     User?          @relation("RoomHeldByUser", fields: [heldByUserId], references: [id], onDelete: SetNull)
  holdExpiresAt  DateTime?
  bookedByUserId Int?           @unique
  bookedByUser   User?          @relation("RoomBookedByUser", fields: [bookedByUserId], references: [id], onDelete: SetNull)
  hostelId       Int
  hostel         Hostel         @relation(fields: [hostelId], references: [id], onDelete: Cascade)
}

model Announcement {
  id                Int                @id @default(autoincrement())
  title             String
  content           String
  targetRole        String             @default("ALL") // "ALL", "STUDENT", "TEACHER", "WARDEN"
  createdAt         DateTime           @default(now())
  announcementReads AnnouncementRead[]
}

model AnnouncementRead {
  userId         Int
  announcementId Int
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@id([userId, announcementId])
}

model SystemSettings {
  id                         Int     @id @default(1)
  courseRegistrationLocked   Boolean @default(false)
  tuitionPaymentLocked       Boolean @default(false)
}

model FeeRecord {
  id            Int            @id @default(autoincrement())
  studentId     Int
  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type          FeeType
  amount        Float
  status        FeeStatus      @default(UNPAID)
  term          String
  paidAt        DateTime?
  admissionYear Int
  createdAt     DateTime       @default(now())

  @@unique([studentId, type, term])
}
